{
  "name": "rn-bridge-to-turbo",
  "version": "1.0.0",
  "description": "Convert React Native Bridge modules to TurboModule specs",
  "main": "dist/cli.js",
  "bin": {
    "rn-bridge-to-turbo": "./bin/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "ts-node tests/runTest.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "react-native",
    "turbomodule",
    "bridge",
    "codegen",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "java-parser": "^3.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "codegenConfig": {
    "name": "AppSpecs",
    "type": "modules",
    "jsSrcsDir": "generated/specs"
  }
}
